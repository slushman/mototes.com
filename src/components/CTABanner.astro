---
interface Props {
  headline?: string;
  subline?: string;
  href?: string;
  ctaLabel?: string;
}

const {
  headline = "Moving day is closer than you think.",
  subline = "Local delivery + pickup included. No cardboard drama.",
  href = "#pricing",
  ctaLabel = "Book your totes",
} = Astro.props;
---

<section id="cta-banner" class="bg-brand py-14 md:py-20">
  <div class="max-w-[1160px] mx-auto px-6 md:px-12 flex flex-col md:flex-row items-center justify-center gap-6 text-center md:text-left">
    <div>
      <h2 class="text-[24px] font-display font-medium text-on-brand mb-1">
        {headline}
      </h2>
      <p class="text-on-brand">
        {subline}
      </p>
    </div>
    <a
      href={href}
      class="inline-block bg-white text-brand font-medium px-7 py-3.5 rounded-md hover:bg-white/90 transition-all cursor-pointer shrink-0"
    >
      {ctaLabel} &rarr;
    </a>
  </div>
</section>
