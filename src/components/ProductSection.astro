---
interface Tier {
  name: string;
  price: string;
  totes: number;
  detail: string;
  popular?: boolean;
  popularLabel?: string;
  bookUrl?: string;
  ariaLabel: string;
}

interface Props {
  id: string;
  bg: "bg-page" | "bg-page-alt";
  headline: string;
  sell: string;
  includes: string;
  footnote?: string;
  tiers: Tier[];
}

const { id, bg, headline, sell, includes, footnote, tiers } = Astro.props;
---

<section id={id} class={`${bg} py-14 md:py-20`}>
  <div class="max-w-[1160px] mx-auto px-6 md:px-12 text-center">
    <h2 class="font-display text-[26px] md:text-[34px] font-medium mb-3">
      {headline}
    </h2>
    <p class="text-text-muted max-w-[560px] mx-auto mb-4">
      {sell}
    </p>
    <p class="text-text-muted max-w-[560px] mx-auto mb-10" set:html={includes}>
    </p>
    {footnote && (
      <p class="text-text-muted text-sm max-w-[560px] mx-auto mb-12" set:html={footnote}>
      </p>
    )}

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 max-w-[1060px] mx-auto items-end">
      {tiers.map((tier) => (
        <div class={`flex flex-col items-center ${tier.popular ? "order-first md:order-none" : ""}`}>
          {tier.popular && (
            <span class="bg-action text-on-action text-sm font-medium uppercase tracking-wider px-3 py-1 rounded-pill mb-2">
              {tier.popularLabel ?? "Most popular"}
            </span>
          )}
          <div
            class:list={[
              "rounded-lg p-6 text-center flex flex-col w-full",
              tier.popular
                ? "bg-brand text-on-brand"
                : "bg-brand-light text-brand-dark",
            ]}
          >
            <span class={`font-medium uppercase tracking-wider mb-2 ${tier.popular ? "text-on-brand" : "text-brand-dark"}`}>
              {tier.name}
            </span>
            <span class="text-[28px] font-medium mb-1">{tier.price}</span>
            <span class={`mb-6 ${tier.popular ? "text-on-brand" : "text-text-muted"}`}>
              {tier.totes} totes &middot; {tier.detail}
            </span>
            <a
              href={tier.bookUrl ?? "#"}
              target={tier.bookUrl ? "_blank" : undefined}
              rel={tier.bookUrl ? "noopener noreferrer" : undefined}
              aria-label={tier.ariaLabel}
              class:list={[
                "inline-block font-medium px-6 py-3 rounded-md transition-all cursor-pointer mt-auto",
                tier.popular
                  ? "bg-white text-brand hover:bg-white/90"
                  : "bg-brand text-on-brand hover:bg-brand-dark",
              ]}
            >
              Book this
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
