---
import ProductSection from "../ProductSection.astro";

interface Props {
  bg?: "bg-page" | "bg-page-alt";
}

const { bg = "bg-page" } = Astro.props;

const tiers = [
  {
    name: "Dorm",
    price: "$349",
    totes: 10,
    detail: "full summer",
    popular: false,
    ariaLabel: "Book this 10 tote moving, rental, and storage package for a dorm",
    bookUrl: "https://square.link/u/TebsiBsy",
  },
  {
    name: "Studio/1-Bed",
    price: "$399",
    totes: 20,
    detail: "full summer",
    popular: true,
    popularLabel: "Full service",
    ariaLabel: "Book this 20 tote moving, rental, and storage package for a studio or 1-bedroom",
    bookUrl: "https://square.link/u/yPK85vbr",
  },
  {
    name: "1-2 Bed",
    price: "$459",
    totes: 30,
    detail: "full summer",
    popular: false,
    ariaLabel: "Book this 30 tote moving, rental, and storage package for a 1 to 2 bedroom",
    bookUrl: "https://square.link/u/oOgGmkEg",
  },
  {
    name: "2 Bed",
    price: "$529",
    totes: 45,
    detail: "full summer",
    popular: false,
    ariaLabel: "Book this 45 tote moving, rental, and storage package for a 2 bedroom",
    bookUrl: "https://square.link/u/KNbtDl9z",
  },
];
---

<ProductSection
  id="mo-totes-and-stow"
  bg={bg}
  headline="Mo', Totes, & Stow"
  sell="The hands-off move. No trucks, no heavy lifting, no move-out weekend. We drop off totes at your dorm, pick them up packed, store everything through summer, and bring them back to your dorm in the fall."
  includes="Every package includes totes, secure summer storage, plus move-out pickup ($99) and move-in delivery ($99) right from your dorm."
  tiers={tiers}
/>
