---
import ProductSection from "../ProductSection.astro";

interface Props {
  bg?: "bg-page" | "bg-page-alt";
}

const { bg = "bg-page-alt" } = Astro.props;

const tiers = [
  {
    name: "Dorm",
    price: "$150",
    totes: 10,
    detail: "full summer",
    popular: false,
    bookUrl: "https://square.link/u/B74l0NUq",
    ariaLabel: "Book this 10 tote rental and storage package for a dorm",
  },
  {
    name: "Studio/1-Bed",
    price: "$200",
    totes: 20,
    detail: "full summer",
    popular: true,
    popularLabel: "Sweet spot",
    bookUrl: "https://square.link/u/1uDLAVO7",
    ariaLabel: "Book this 20 tote rental and storage package for a studio or 1-bedroom",
  },
  {
    name: "1-2 Bed",
    price: "$260",
    totes: 30,
    detail: "full summer",
    popular: false,
    bookUrl: "https://square.link/u/Jk9glhSw",
    ariaLabel: "Book this 30 tote rental and storage package for a 1 to 2 bedroom",
  },
  {
    name: "2 Bed",
    price: "$325",
    totes: 45,
    detail: "full summer",
    popular: false,
    bookUrl: "https://square.link/u/et7eOs02",
    ariaLabel: "Book this 45 tote rental and storage package for a 2 bedroom",
  },
];
---

<ProductSection
  id="totes-and-stow"
  bg={bg}
  headline="Totes & Stow"
  sell="We drop off totes on campus. Pack them, bring them to our campus spot, and we'll store everything in our clean, secure facility all summer. Pick them up from campus in the fall."
  includes="Every package includes on-campus tote drop-off, secure summer storage, and on-campus pickup in the fall."
  tiers={tiers}
/>
