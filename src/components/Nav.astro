---
const links = [
  { label: "How it works", href: "#how-it-works" },
  { label: "Pricing", href: "#pricing" },
  { label: "Campuses", href: "#campuses" },
];
---

<nav id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-200" data-nav>
  <div class="max-w-[1160px] mx-auto px-6 md:px-12 flex items-center justify-between h-16">
    <a href="/" class="text-brand font-brand font-semibold text-2xl uppercase tracking-wide">
      MO Totes
    </a>

    <div class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a href={link.href} class="text-text-primary hover:text-brand transition-colors">
          {link.label}
        </a>
      ))}
    </div>

    <div class="hidden md:block">
      <a href="#pricing" class="inline-block bg-action text-on-action font-medium px-5 py-2.5 rounded-sm hover:bg-action-dark transition-all cursor-pointer">
        Book now
      </a>
    </div>

    <button class="md:hidden flex items-center justify-center w-11 h-11 text-text-primary" data-menu-toggle aria-label="Toggle menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6" class="menu-open" />
        <line x1="3" y1="12" x2="21" y2="12" class="menu-open" />
        <line x1="3" y1="18" x2="21" y2="18" class="menu-open" />
        <line x1="6" y1="6" x2="18" y2="18" class="menu-close hidden" />
        <line x1="6" y1="18" x2="18" y2="6" class="menu-close hidden" />
      </svg>
    </button>
  </div>

  <div class="md:hidden hidden bg-page border-t border-border" data-mobile-menu>
    <div class="px-6 py-4 flex flex-col gap-4">
      {links.map((link) => (
        <a href={link.href} class="text-text-primary hover:text-brand transition-colors py-2" data-menu-link>
          {link.label}
        </a>
      ))}
      <a href="#pricing" class="inline-block bg-action text-on-action font-medium px-5 py-2.5 rounded-sm hover:bg-action-dark transition-all cursor-pointer text-center" data-menu-link>
        Book now
      </a>
    </div>
  </div>
</nav>

<script>
  const nav = document.querySelector("[data-nav]") as HTMLElement;
  const toggle = document.querySelector("[data-menu-toggle]") as HTMLButtonElement;
  const menu = document.querySelector("[data-mobile-menu]") as HTMLElement;
  const menuLinks = document.querySelectorAll("[data-menu-link]");
  const openLines = document.querySelectorAll(".menu-open");
  const closeLines = document.querySelectorAll(".menu-close");

  let menuOpen = false;

  function updateNav() {
    if (window.scrollY > 60) {
      nav.classList.add("bg-page", "shadow-[0_1px_0_var(--color-border)]");
    } else {
      nav.classList.remove("bg-page", "shadow-[0_1px_0_var(--color-border)]");
    }
  }

  function toggleMenu() {
    menuOpen = !menuOpen;
    menu.classList.toggle("hidden", !menuOpen);
    openLines.forEach((l) => l.classList.toggle("hidden", menuOpen));
    closeLines.forEach((l) => l.classList.toggle("hidden", !menuOpen));
  }

  window.addEventListener("scroll", updateNav, { passive: true });
  updateNav();

  toggle.addEventListener("click", toggleMenu);
  menuLinks.forEach((link) => link.addEventListener("click", () => {
    if (menuOpen) toggleMenu();
  }));
</script>
