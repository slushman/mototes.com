---
import type { SchoolData } from "../../data/schools";

interface Props {
  school: SchoolData;
}

const { school } = Astro.props;
const { dates } = school;
---

<section id="dates" class="bg-action text-on-action py-14 md:py-20">
  <div class="max-w-[1160px] mx-auto px-6 md:px-12">
    <h2 class="font-display text-[26px] md:text-[34px] font-medium text-center mb-12">
      Key dates for {school.shortName} students
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 max-w-[700px] mx-auto">
      <div class="text-center">

        <p class="font-medium mb-1">Spring move-out</p>
        <p class="text-on-action">{dates.springMoveOut}</p>
      </div>
      {dates.summerStorage && (
        <div class="text-center">

          <p class="font-medium mb-1">Summer storage</p>
          <p class="text-on-action">{dates.summerStorage}</p>
        </div>
      )}
      <div class="text-center">

        <p class="font-medium mb-1">Fall move-in</p>
        <p class="text-on-action">{dates.fallMoveIn}</p>
      </div>
    </div>

    {school.storageLocation && (
      <p class="text-center mt-10 text-on-action">
        Storage facility: {school.storageLocation}
      </p>
    )}
  </div>
</section>
