---
const navLinks = [
  { label: "How it works", href: "#how-it-works" },
  { label: "Pricing", href: "#pricing" },
  { label: "Campuses", href: "#campuses" },
  { label: "FAQ", href: "#faq" },
];

const campuses = [
  { name: "Mizzou", href: "/university-of-missouri" },
];
---

<footer class="bg-[#2C2C2A] text-white">
  <div class="max-w-[1160px] mx-auto px-6 md:px-12 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <div>
        <a href="/" class="text-white font-brand font-semibold text-2xl mb-3 inline-block uppercase tracking-wide">
          MO Totes
        </a>
        <p class="text-sm text-[#B0B0B0] leading-relaxed">
          Reusable tote rentals built for college students. No cardboard, no tape, no stress.
        </p>
      </div>

      <div>
        <h4 class="text-xs font-medium uppercase tracking-wider mb-4 text-[#B0B0B0]">Links</h4>
        <ul class="flex flex-col gap-2">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-[#B0B0B0] hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-medium uppercase tracking-wider mb-4 text-[#B0B0B0]">Campuses</h4>
        <ul class="flex flex-col gap-2">
          {campuses.map((campus) => (
            <li><a href={campus.href} class="text-sm text-[#B0B0B0] hover:text-white transition-colors">{campus.name}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-medium uppercase tracking-wider mb-4 text-[#B0B0B0]">Social</h4>
        <div class="flex gap-4">
          <a href="#" class="text-[#B0B0B0] hover:text-white transition-colors" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" />
              <circle cx="12" cy="12" r="5" />
              <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none" />
            </svg>
          </a>
          <a href="#" class="text-[#B0B0B0] hover:text-white transition-colors" aria-label="TikTok">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1 0-5.78 2.92 2.92 0 0 1 .88.13v-3.5a6.37 6.37 0 0 0-.88-.07 6.26 6.26 0 0 0 0 12.51 6.26 6.26 0 0 0 6.26-6.26V8.55a8.32 8.32 0 0 0 3.84.96V6.09a4.85 4.85 0 0 1-.55.02l.55.58z" />
            </svg>
          </a>
          <a href="#" class="text-[#B0B0B0] hover:text-white transition-colors" aria-label="Twitter">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4l11.733 16h4.267l-11.733-16zM4 20l6.768-6.768M13.232 10.232L20 4" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-white/15 mt-12 pt-6 text-center text-xs text-[#B0B0B0]">
      &copy; {new Date().getFullYear()} MO Totes LLC &middot; Made with less cardboard.
    </div>
  </div>
</footer>
