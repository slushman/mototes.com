---
const navLinks = [
  { label: "How it works", href: "#how-it-works" },
  { label: "Pricing", href: "#pricing" },
  { label: "Campuses", href: "#campuses" },
  { label: "FAQ", href: "#faq" },
];

const campuses = [
  { name: "Mizzou", href: "/university-of-missouri" },
];
---

<footer class="bg-[#2C2C2A] text-white">
  <div class="max-w-[1160px] mx-auto px-6 md:px-12 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <div>
        <a href="/" class="text-white font-brand font-semibold text-2xl mb-3 inline-block uppercase tracking-wide">
          MO Totes
        </a>
        <p class="text-sm text-[#B0B0B0] leading-relaxed">
          Reusable tote rentals built for college students. No cardboard, no tape, no stress.
        </p>
      </div>

      <div>
        <h4 class="text-xs font-medium uppercase tracking-wider mb-4 text-[#B0B0B0]">Links</h4>
        <ul class="flex flex-col gap-2">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-[#B0B0B0] hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-medium uppercase tracking-wider mb-4 text-[#B0B0B0]">Campuses</h4>
        <ul class="flex flex-col gap-2">
          {campuses.map((campus) => (
            <li><a href={campus.href} class="text-sm text-[#B0B0B0] hover:text-white transition-colors">{campus.name}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-medium uppercase tracking-wider mb-4 text-[#B0B0B0]">Social</h4>
        <div class="flex gap-4">
          <a href="https://facebook.com/movingtotes" target="_blank" rel="noopener noreferrer" class="text-[#B0B0B0] hover:text-white transition-colors" aria-label="MO Totes on Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-white/15 mt-12 pt-6 text-center text-xs text-[#B0B0B0]">
      &copy; {new Date().getFullYear()} MO Totes LLC &middot; Made with less cardboard.
    </div>
  </div>
</footer>
