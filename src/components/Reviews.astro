---
const reviews = [
  {
    quote: "Easiest move of my life. No tape, no boxes collapsing.",
    name: "Jordan M.",
    school: "Mizzou '26",
  },
  {
    quote: "Dropped them off the night before finals week. Genuinely saved me.",
    name: "Priya K.",
    school: "WashU '25",
  },
  {
    quote: "I've moved three times with MO Totes. Never going back to cardboard.",
    name: "Marcus L.",
    school: "SLU '24",
  },
];
---

<section id="reviews" class="bg-page-alt py-14 md:py-20">
  <div class="max-w-[1160px] mx-auto px-6 md:px-12">
    <h2 class="font-display text-[26px] md:text-[34px] font-medium text-center mb-12">
      Students who've moved the smart way.
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {reviews.map((review) => (
        <div class="bg-base border border-border rounded-lg p-5 px-6">
          <div class="text-accent mb-3" role="img" aria-label="5 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="text-text-primary italic leading-relaxed mb-4">
            &ldquo;{review.quote}&rdquo;
          </p>
          <p class="text-text-muted">
            {review.name}, {review.school}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
