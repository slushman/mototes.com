---
const products = [
  {
    name: "Totes",
    tagline: "Just the totes",
    description: "Reusable totes delivered to your door for move-in or move-out. Pack, move, and schedule a pickup when you're done.",
    href: "#totes",
  },
  {
    name: "Totes & Stow",
    tagline: "Totes + storage",
    description: "Everything in Totes, plus secure summer storage. Bring your packed totes to the campus drop-off point and pick them up in the fall.",
    href: "#totes-and-stow",
  },
  {
    name: "Mo', Totes, & Stow",
    tagline: "Totes + storage + moving",
    description: "The hands-off option. We pick up your packed totes from your dorm, store them all summer, and deliver them back when you return.",
    href: "#mo-totes-and-stow",
  },
];
---

<section id="pricing" class="bg-page-alt py-14 md:py-20">
  <div class="max-w-[900px] mx-auto px-6 md:px-12 text-center">
    <h2 class="font-display text-[26px] md:text-[34px] font-medium mb-3">
      Three ways to move. Pick yours.
    </h2>
    <p class="text-text-muted max-w-[560px] mx-auto mb-12">
      Whether you just need totes or want the full door-to-door experience, we've got a package for you.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {products.map((product) => (
        <a href={product.href} class="group rounded-lg bg-brand-light text-brand-dark p-6 text-left hover:bg-brand hover:text-on-brand hover:scale-[1.02] transition-all">
          <p class="text-sm uppercase tracking-wider font-medium mb-1">
            {product.tagline}
          </p>
          <h3 class="font-display text-lg font-medium mb-2">
            {product.name}
          </h3>
          <p class="text-sm leading-relaxed">
            {product.description}
          </p>
        </a>
      ))}
    </div>
  </div>
</section>
