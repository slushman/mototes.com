---
const campuses = [
  { name: "Mizzou", href: "/university-of-missouri" },
];
---

<section id="campuses" class="bg-brand py-10 md:py-12">
  <div class="max-w-[1160px] mx-auto px-6 md:px-12">
    <div class="flex flex-col items-center justify-center gap-3">
      <span class="text-on-brand uppercase tracking-wider font-medium">Serving students at</span>
      <div class="flex flex-wrap items-center justify-center gap-2">
        {campuses.map((campus) => (
          <a href={campus.href} class="inline-block border border-on-brand/30 rounded-sm px-4 py-1.5 font-medium text-on-brand hover:bg-on-brand/10 transition-colors">
            {campus.name}
          </a>
        ))}
      </div>
      <p class="text-on-brand/80 mt-2">
        Want us at your campus?
        <a
          id="campus-email-cta"
          class="underline text-on-brand font-medium hover:text-on-brand/80 transition-colors"
          data-u="chris"
          data-d="mototes.com"
          role="link"
          aria-label="Send us an email"
        >Let us know!</a>
      </p>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const link = document.getElementById('campus-email-cta');
    if (link) {
      const u = link.getAttribute('data-u');
      const d = link.getAttribute('data-d');
      link.setAttribute('href', 'mai' + 'lto:' + u + '@' + d);
    }
  });
</script>
