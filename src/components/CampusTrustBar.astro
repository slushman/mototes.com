---
const campuses = [
  { name: "Mizzou", href: "/university-of-missouri" },
];
---

<section id="campuses" class="bg-brand py-10 md:py-12">
  <div class="max-w-[1160px] mx-auto px-6 md:px-12">
    <div class="flex flex-col items-center justify-center gap-3">
      <span class="text-on-brand uppercase tracking-wider font-medium">Serving students at</span>
      <div class="flex flex-wrap items-center justify-center gap-2">
        {campuses.map((campus) => (
          <a href={campus.href} class="inline-block border border-on-brand/30 rounded-sm px-4 py-1.5 font-medium text-on-brand hover:bg-on-brand/10 transition-colors">
            {campus.name}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
